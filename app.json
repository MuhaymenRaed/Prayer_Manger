{
  "expo": {
    "name": "Yaqeen",
    "slug": "PrayerManger",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yaqeen",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "locales": {
      "en": "./locales/en.json",
      "ar": "./locales/ar.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.yaqeen.com"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#15803D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "app.yaqeen.com",
      "versionCode": 3,
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#15803D",
          "dark": {
            "backgroundColor": "#15803D"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#15803D",
          "defaultChannel": "prayers",
          "enableBackgroundRemoteNotifications": false,
          "sounds": [
            "./assets/sounds/sound1.mp3",
            "./assets/sounds/sound2.mp3",
            "./assets/sounds/sound3.mp3",
            "./assets/sounds/sound4.mp3",
            "./assets/sounds/sound5.mp3",
            "./assets/sounds/sound6.mp3",
            "./assets/sounds/sound7.mp3",
            "./assets/sounds/sound8.mp3",
            "./assets/sounds/sound9.mp3",
            "./assets/sounds/sound10.mp3",
            "./assets/sounds/sound11.mp3",
            "./assets/sounds/sound12.mp3",
            "./assets/sounds/sound13.mp3",
            "./assets/sounds/sound14.mp3",
            "./assets/sounds/sound15.mp3",
            "./assets/sounds/sound16.mp3",
            "./assets/sounds/sound17.mp3",
            "./assets/sounds/sound18.mp3",
            "./assets/sounds/sound19.mp3",
            "./assets/sounds/sound20.mp3"
          ]
        }
      ],
      "./plugins/withArabicAppName",
      "./plugins/withReleaseSlim",
      "./plugins/withForceLtr",
      "./plugins/withReleaseSigning",
      "./plugins/withReliableAlarms",
      "./plugins/withResourceKeep",
      "expo-audio",
      "expo-background-task",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-keep class expo.modules.** { *; }\n-keep class com.facebook.jni.** { *; }"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5c153a02-61c4-4448-a39e-170fd0e38018"
      }
    }
  }
}
