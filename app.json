{
  "expo": {
    "name": "Yaqeen",
    "slug": "PrayerManger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yaqeen",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "locales": {
      "en": "./locales/en.json",
      "ar": "./locales/ar.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.PrayerManger"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#15803D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.PrayerManger"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#15803D",
          "dark": {
            "backgroundColor": "#15803D"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#15803D",
          "defaultChannel": "prayers",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "./plugins/withArabicAppName"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5c153a02-61c4-4448-a39e-170fd0e38018"
      }
    }
  }
}
